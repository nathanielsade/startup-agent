# ── Local dev ───────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty for the single-tenant SQLite path (no auth, dev user).
# Set it to run the cloud (multi-user Postgres) path locally against Docker:
#   DATABASE_URL=postgresql://postgres:devpass@localhost:5433/startup_agent

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI). Use the pooled
# connection (port 6543) for the API; the batch can use the direct one.
DATABASE_URL=

# ── Auth (Supabase) ──────────────────────────────────────────────────────────
# Supabase → Settings → API → JWT Secret. Empty locally → dev-user fallback.
SUPABASE_JWT_SECRET=
SUPABASE_URL=

# ── Embeddings ───────────────────────────────────────────────────────────────
# "local"  → sentence-transformers (offline, needs the dev deps / torch)
# "openai" → hosted embeddings (deploy default; small container, no torch)
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── LLM (server-side keys; never user-provided in cloud) ─────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DAILY_CAP=30

# ── CORS (deploy) ────────────────────────────────────────────────────────────
# Comma-separated frontend origin(s), e.g. https://jobscout.vercel.app
CORS_ORIGINS=

# ── Frontend (frontend/.env — VITE_* are build-time) ─────────────────────────
# VITE_SUPABASE_URL=https://<project>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon public key>
# VITE_API_BASE=https://startup-agent-api.onrender.com
